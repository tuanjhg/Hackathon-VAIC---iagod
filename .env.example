POSTGRES_DB=needwise
POSTGRES_USER=needwise
POSTGRES_PASSWORD=needwise
DATABASE_URL=postgresql+psycopg://needwise:needwise@postgres:5432/needwise
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

# Tên miền của bạn (ví dụ: needwise.com). Dùng cho Caddy tự động cấu hình HTTPS
DOMAIN_NAME=localhost

# LLM router (ADR A6) -- xem docs/pipelines.md §6.5/§6.9. Mặc định trỏ
# localhost:8001; khi vLLM chạy trên VM FPT AI Factory riêng, đổi
# LLM_BASE_URL thành http://<IP public VM>:8001/v1 trong .env thật (không commit).
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=qwen3-32b-fp8
LLM_API_KEY=

# --- DEV PROFILE (18/07): dùng OpenRouter TRƯỚC khi VM GPU sẵn sàng ---
# Bỏ comment 3 dòng dưới trong .env thật khi dev. Model qwen/qwen3-32b là
# ĐÚNG model sẽ self-host (ADR A2) -> prompt/giọng văn dev khớp bản demo,
# và năng lực ngang tầm Qwen2.5-32B như yêu cầu (không dùng model to hơn
# để khỏi ảo tưởng chất lượng). KHÔNG commit API key. Ngày demo: comment
# lại 3 dòng này để quay về vLLM on-prem.
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen3-32b
# LLM_API_KEY=sk-or-v1-thay-bang-key-that
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=gpt-4o-mini

# vLLM service (docker-compose.vllm.yml) -- chỉ dùng khi bật trên VM GPU,
# xem docs/pipelines.md §6.9 "Vận hành vLLM trên FPT AI Factory".
VLLM_MODEL_PATH=Qwen/Qwen3-32B-FP8
VLLM_PORT=8001
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192
HF_TOKEN=

