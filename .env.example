DATABASE_URL=postgresql://postgres:password@localhost:5432/product_catalog
POLICY_DATABASE_URL=postgresql://postgres:password@localhost:5432/product_catalog
POLICY_VECTOR_SCHEMA=policy_rag

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=product_catalog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

CSV_DATA_DIR=./data
IMPORT_BATCH_SIZE=500

# Existing NeedWise application settings
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

# Tên miền của bạn (ví dụ: needwise.com). Dùng cho Caddy tự động cấu hình HTTPS
DOMAIN_NAME=localhost

# LLM router (ADR A6, model + hạ tầng theo ADR A2'' — xem docs/research/
# dmx-tech-decisions.md, supersedes A2/A2'). Không tự host, không dùng FPT AI
# Factory nữa: model chính là Qwen3.6-27B qua API key OpenRouter.
#
# XÁC NHẬN TRƯỚC KHI CHẠY THẬT: LLM_MODEL bên dưới là tên model dự kiến trên
# OpenRouter -- kiểm tra đúng slug thật trong catalog OpenRouter (openrouter.ai/models)
# trước khi set key thật, slug có thể khác (vd hậu tố -instruct).
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.6-27b
LLM_API_KEY=

# Fallback (ADR A6) khi request lỗi/quá tải -- tắt mặc định, chưa chọn nhà
# cung cấp thứ 2 (chỉ còn 1 provider = OpenRouter cho cả primary hiện tại).
# Bật + điền khi có key dự phòng.
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=

# --- ARCHIVED (18/07): self-host vLLM trên VM GPU thuê -- KHÔNG dùng nữa,
# xem ADR A2' (superseded). Giữ lại biến + docker-compose.vllm.yml phòng khi
# roadmap pilot (ADR A8) cần quay lại self-host; không set trong .env thật. ---
