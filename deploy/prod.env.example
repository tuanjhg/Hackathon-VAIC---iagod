# Store the real version in Secret Manager via scripts/gcp/02-put-secret.sh.
POSTGRES_DB=needwise
POSTGRES_USER=needwise
POSTGRES_PASSWORD=replace-with-a-long-random-value
# URL-encode special characters in the password portion of these DSNs.
DATABASE_URL=postgresql+psycopg://needwise:replace-with-a-long-random-value@postgres:5432/needwise
POLICY_DATABASE_URL=postgresql+psycopg://needwise:replace-with-a-long-random-value@postgres:5432/needwise
DOMAIN_NAME=needwise.example.com
# Use https with a real DNS name. Use http only when accessing a bare Compute Engine public IP.
SITE_SCHEME=https
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.6-27b
LLM_API_KEY=
CHAT_PIPELINE=mock
LLM_FALLBACK_ENABLED=false
